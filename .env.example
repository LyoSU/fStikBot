# ── Environment ───────────────────────────────────────────────
NODE_ENV=development

# ── Telegram Bot ─────────────────────────────────────────────
BOT_TOKEN=
# Main bot token for cross-bot messaging (e.g. broadcasting). Falls back to BOT_TOKEN if same bot.
MAIN_BOT_TOKEN=
# Public domain for webhook mode (omit to use long-polling)
BOT_DOMAIN=
# Port the webhook HTTP server listens on (default: 2500)
WEBHOOK_PORT=2500

# ── Telegram MTProto (used for downloading large files) ──────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/fstikbot
# Optional separate Atlas URI for read replicas / analytics (falls back to MONGODB_URI)
ATLAS_MONGODB_URI=

# ── Redis (queues, rate-limiting, sessions) ──────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── OpenAI (pack moderation) ─────────────────────────────────
OPENAI_API_KEY=

# ── Tenor (GIF search in inline packs) ───────────────────────
TENOR_KEY=

# ── GramAds (optional ad integration) ────────────────────────
GRAMADS_TOKEN=
